{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src/worker",
    "outDir": "dist",
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": false,
    "noEmit": false
  },
  "include": ["src/worker/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
